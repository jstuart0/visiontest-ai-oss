# ===========================================
# VisionTest AI - Environment Configuration
# ===========================================
# Copy this file to .env and fill in values.
# Required variables are marked with [REQUIRED].

# --- Database ---
# [REQUIRED] PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/visiontest

# --- Redis ---
# [REQUIRED] Redis connection string (used for job queue and pub/sub)
REDIS_URL=redis://localhost:6379

# --- Authentication ---
# [REQUIRED] Secret for signing JWT access tokens (min 32 chars)
# Generate with: openssl rand -hex 32
JWT_SECRET=
# [REQUIRED] Secret for signing JWT refresh tokens (min 32 chars)
# Generate with: openssl rand -hex 32
JWT_REFRESH_SECRET=

# --- MinIO (Object Storage) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
SCREENSHOT_BUCKET=visiontest-screenshots

# --- Application ---
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=debug

# --- Worker ---
WORKER_CONCURRENCY=2
WORKER_ID=worker-local

# --- Frontend (baked at build time for Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:3001

# --- Email (Optional - for password reset and invites) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@yourdomain.com
# FRONTEND_URL=http://localhost:3000

# --- Integrations (Optional) ---
# ANTHROPIC_API_KEY=     # For AI-powered features
