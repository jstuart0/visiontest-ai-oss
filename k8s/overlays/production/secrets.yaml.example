# Copy this file to secrets.yaml and fill in your values
# DO NOT commit secrets.yaml to version control
apiVersion: v1
kind: Secret
metadata:
  name: visiontest-secrets
  namespace: visiontest
type: Opaque
stringData:
  database-url: "postgresql://visiontest:CHANGE_ME@your-postgres-host:5432/visiontest"
  redis-url: "redis://:CHANGE_ME@redis:6379"
  redis-password: "CHANGE_ME"
  jwt-secret: "CHANGE_ME_minimum_32_characters_use_openssl_rand_hex_32"
  jwt-refresh-secret: "CHANGE_ME_minimum_32_characters_use_openssl_rand_hex_32"
  minio-access-key: "CHANGE_ME"
  minio-secret-key: "CHANGE_ME"
