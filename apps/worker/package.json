{
  "name": "@visiontest/worker",
  "version": "2.0.0",
  "private": true,
  "description": "VisionTest AI - Test Execution Worker",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.js --external:@visiontest/database --external:@prisma/client --external:playwright --external:jimp --external:pixelmatch --external:pngjs --external:minio --external:sharp --external:bullmq --external:ioredis --external:pino --external:pino-pretty --external:simple-git --external:@octokit/rest --external:diff --external:@kubernetes/client-node",
    "build:types": "tsc --emitDeclarationOnly",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@visiontest/database": "*",
    "@visiontest/types": "*",
    "bullmq": "^5.1.0",
    "ioredis": "^5.3.2",
    "jimp": "^0.22.10",
    "minio": "^7.1.3",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "pixelmatch": "^5.3.0",
    "playwright": "^1.40.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.33.2",
    "simple-git": "^3.27.0",
    "@octokit/rest": "^21.0.0",
    "diff": "^7.0.0",
    "@kubernetes/client-node": "^1.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/node": "^20.10.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/diff": "^6.0.0",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^1.6.1",
    "esbuild": "^0.27.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.1.0"
  }
}
