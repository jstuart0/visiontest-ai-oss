{
  "name": "visiontest-ai",
  "version": "2.0.0",
  "private": true,
  "description": "AI-Powered Visual Regression Testing Platform - Hospital Grade",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "mcp:dev": "npm run dev --workspace=@visiontest/mcp",
    "mcp:build": "npm run build --workspace=@visiontest/mcp",
    "db:generate": "npm run generate --workspace=@visiontest/database",
    "db:migrate": "npm run migrate --workspace=@visiontest/database",
    "db:seed": "npm run seed --workspace=@visiontest/database",
    "clean": "turbo run clean && rm -rf node_modules",
    "dogfood": "npx tsx scripts/dogfood/index.ts",
    "dogfood:clean": "npx tsx scripts/dogfood/index.ts --clean"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/pngjs": "^6.0.5",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.2.0",
  "optionalDependencies": {
    "lightningcss-darwin-arm64": "^1.31.1"
  }
}
