# VisionTest AI - Web Frontend
ARG NODE_BASE_IMAGE=node:20-slim
FROM ${NODE_BASE_IMAGE} AS builder

WORKDIR /app

# Build-time env vars (Next.js bakes NEXT_PUBLIC_* at build time)
ARG NEXT_PUBLIC_API_URL=http://localhost:3001/api
ARG NEXT_PUBLIC_WS_URL=http://localhost:3001
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL

# Copy package files
COPY package*.json ./
COPY turbo.json ./
COPY apps/web/package*.json ./apps/web/

# Install dependencies
RUN npm ci

# Copy source files
COPY apps/web ./apps/web

# Install platform-specific lightningcss binary for Tailwind CSS
RUN npm install lightningcss-linux-x64-gnu || true

# Build Next.js app
WORKDIR /app/apps/web
RUN npm run build

# Production stage
ARG NODE_BASE_IMAGE=node:20-slim
FROM ${NODE_BASE_IMAGE} AS runner

WORKDIR /app

# Create non-root user
RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nodejs

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# Copy built app - Next.js standalone with monorepo
COPY --chown=nodejs:nodejs --from=builder /app/apps/web/.next/standalone ./
COPY --chown=nodejs:nodejs --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --chown=nodejs:nodejs --from=builder /app/apps/web/public ./apps/web/public

EXPOSE 3000

USER nodejs

CMD ["node", "apps/web/server.js"]
